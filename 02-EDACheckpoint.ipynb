    "import pandas as pd\n",
    "import numpy as np\n",
    "import os\n",
    "\n",
    "df = pd.read_csv('data/00-raw/titanic.csv')\n",
    "\n",
    "print(\"Shape:\", df.shape)\n",
    "missing = df.isnull().sum()\n",
    "missing_pct = (missing / len(df) * 100).round(2)\n",
    "print(\"Missing values: \", pd.DataFrame({'count': missing, 'pct': missing_pct})[missing > 0])\n",
    "\n",
    "# Drop rows missing age (177) or embarked (2)\n",
    "df = df.dropna(subset=['age', 'embarked'])\n",
    "\n",
    "df['family_size'] = df['sibsp'] + df['parch'] + 1\n",
    "df['is_alone'] = (df['family_size'] == 1).astype(int)\n",
    "df['fare_log'] = np.log1p(df['fare'])\n",
    "df['sex_enc'] = df['sex'].map({'male': 0, 'female': 1})\n",
    "df['embarked_enc'] = df['embarked'].map({'S': 0, 'C': 1, 'Q': 2})\n",
    "\n",
    "main_features = ['pclass', 'sex_enc', 'age', 'fare_log', 'family_size', 'is_alone', 'embarked_enc']\n",
    "print(\"Summary stats: \", df[main_features].describe().round(2))\n",
    "print(\"Final shape: \", df.shape)\n",
    "\n",
    "os.makedirs('data/02-processed', exist_ok=True)\n",
    "df.to_csv('data/02-processed/titanic_clean.csv', index=False)\n",
    "print(\"Saved to data/02-processed/titanic_clean.csv\")"
