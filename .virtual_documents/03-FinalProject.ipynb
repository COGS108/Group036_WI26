





























## import critical modules
import os
%config InlineBackend.figure_format ='retina'

import pandas as pd

import numpy as np

import matplotlib as mpl
import matplotlib.pyplot as plt
import matplotlib.style as style

plt.rcParams['figure.figsize'] = (12, 5)

import seaborn as sns

sns.set(font_scale=1.2, style="white")

import statsmodels.api as sm
from statsmodels.stats.multicomp import pairwise_tukeyhsd as tukeyhsd

from scipy import stats
from scipy.stats import f_oneway as anova

%config InlineBackend.figure_format ='retina'











df = pd.read_csv('data/00-raw/titanic.csv')
print(f"Shape:, {df.shape}\n")
print(f"Data types:\n {df.dtypes}\n")

missing = df.isnull().sum()
missing_pct = (missing / len(df) * 100).round(2)
print("Missing values:\n", pd.DataFrame({'count': missing, 'pct': missing_pct})[missing > 0],"\n")

# drop rows where Age is missing
df = df.dropna(subset='age')

# drop deck entirely
df = df.drop('deck', axis = 1)

# drop the two data points corresponding to missing embarkations
df = df.dropna(subset=['embarked','embark_town'])

# Flag fare outliers
fare_cutoff = df['fare'].mean() + 3 * df['fare'].std()
print(f"Fare outliers (>{fare_cutoff:.2f}): {len(df[df['fare'] > fare_cutoff])} rows\n")

print("Summary stats:\n", df[['survived', 'pclass', 'age', 'fare']].describe().round(2),"\n")
print("Final shape:", df.shape)

os.makedirs('data/02-processed', exist_ok=True)
df.to_csv('data/02-processed/titanic_clean.csv', index=False)
print("Saved to data/02-processed/titanic_clean.csv")





titanic = pd.read_csv('data/02-processed/titanic_clean.csv')








nonsurvivors, survivors = [x for _, x  in titanic.groupby(titanic['survived'] == 1)]

female_survivors, male_survivors = [x for _, x  in survivors.groupby(titanic['sex'] == 'male')]
female_nonsurvivors, male_nonsurvivors = [x for _, x  in nonsurvivors.groupby(titanic['sex'] == 'male')]

print("")
print("Total Passengers (With Valid Age): ", titanic.shape[0], "\n")
print("Male Survivors: ", male_survivors.shape[0])
print("Female Survivors: ", female_survivors.shape[0])
print("Male Nonsurvivors: ", male_nonsurvivors.shape[0])
print("Female Nonsurvivors: ", female_nonsurvivors.shape[0], "\n")

print("Average Male Survivors Age: ", male_survivors['age'].mean().round(2))
print("Average Female Survivors Age: ", female_survivors['age'].mean().round(2))
print("Average Male Nonsurvivors Age: ", male_nonsurvivors['age'].mean().round(2))
print("Average Female Nonsurvivors Age: ", female_nonsurvivors['age'].mean().round(2), "\n")

print("Survivor Stats:\n", survivors[["age"]].describe().round(2), "\n")
print("Nonsurvivor Stats:\n", nonsurvivors[["age"]].describe().round(2),"\n")





survivor_palette = ["#228b22","#b22222"]

survivor_plot = sns.histplot(
    data = titanic,
    x = 'alive',
    hue = 'alive',
    hue_order = ['yes', 'no'],
    palette = survivor_palette,
    stat = 'probability',
    multiple = 'dodge',
    shrink = 0.8)
plt.xlabel("Alive?")
plt.ylabel("Proportion")
plt.ylim(0,1)

plt.show()


survivor_plot_gendered = sns.histplot(
    data=titanic, 
    x = "sex", 
    hue = 'alive', 
    common_norm = False, 
    multiple = 'dodge', 
    stat = 'probability', 
    hue_order = ['no', 'yes'], 
    palette = survivor_palette[::-1], 
    shrink = 0.8)
plt.title("Male vs Female Survival Data")
plt.ylabel("Proportion")
plt.ylim(0,1)
plt.show()





chi_squared_test = stats.chi2_contingency(
    [[male_survivors.shape[0], male_nonsurvivors.shape[0]], 
     [female_survivors.shape[0], female_nonsurvivors.shape[0]]]
)
print("\nChi-Squared Test:")
print("Statistic: ", chi_squared_test.statistic)
print("P-Value: ", chi_squared_test.pvalue)





age_plot = sns.histplot(
    data = titanic,
    x = 'age',
    hue = 'survived',
    palette = survivor_palette,
    multiple = 'stack'
)
plt.show()





